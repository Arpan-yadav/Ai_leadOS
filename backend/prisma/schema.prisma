// This is your Prisma schema file
// Sprint 1 — Backend Team Deliverable
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  EXECUTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum LeadSource {
  WHATSAPP
  EMAIL
  META_LEADS
  LINKEDIN
  WEBSITE
  COLD_OUTREACH
  REFERRAL
}

enum DealStage {
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  CLOSING
  WON
  LOST
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum EventCategory {
  CRM
  COMMUNICATION
  AI
  AUTOMATION
  SYSTEM
}

// ─── User Entity ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EXECUTIVE)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leads      Lead[]
  deals      Deal[]
  tasks      Task[]
  activities Activity[]
  workflows  Workflow[]
  sequences  Sequence[]

  @@map("users")
}

// ─── Lead Entity ──────────────────────────────────────────────────────────────

model Lead {
  id            String     @id @default(cuid())
  name          String
  email         String
  company       String
  title         String?
  phone         String?
  website       String?
  linkedin      String?
  status        LeadStatus @default(NEW)
  source        LeadSource @default(WEBSITE)
  score         Int        @default(0)
  lastContacted DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  assignedTo   User?       @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  deals        Deal[]
  tasks        Task[]
  activities   Activity[]
  aiInsights   AIInsight[]
  enrollments  SequenceEnrollment[]

  @@map("leads")
}

// ─── Deal Entity ──────────────────────────────────────────────────────────────

model Deal {
  id                String    @id @default(cuid())
  title             String
  amount            Float
  stage             DealStage @default(DISCOVERY)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  lead   Lead   @relation(fields: [leadId], references: [id])
  leadId String
  owner  User   @relation(fields: [ownerId], references: [id])
  ownerId String

  @@map("deals")
}

// ─── Task Entity ──────────────────────────────────────────────────────────────

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String   @default("medium") // low | medium | high
  status      String   @default("pending") // pending | completed
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  assignedTo   User   @relation(fields: [assignedToId], references: [id])
  assignedToId String
  lead         Lead?  @relation(fields: [leadId], references: [id])
  leadId       String?

  @@map("tasks")
}

// ─── Activity Entity ──────────────────────────────────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  type      String   // email | call | meeting | note | whatsapp | ai_automation
  content   String
  timestamp DateTime @default(now())
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String
  lead   Lead   @relation(fields: [leadId], references: [id])
  leadId String

  @@map("activities")
}

// ─── AI Insight Entity ────────────────────────────────────────────────────────

model AIInsight {
  id              String   @id @default(cuid())
  analysis        String
  opportunities   String[] // Array of opportunity strings
  websiteAudit    String?
  sentiment       String   // positive | neutral | negative
  qualityScore    Int
  qualityReason   String
  nextAction      String?
  rawResponse     Json?    // Full Gemini response stored for reference
  model           String   @default("gemini-1.5-flash")
  promptKey       String?
  createdAt       DateTime @default(now())

  // Relations
  lead   Lead   @relation(fields: [leadId], references: [id])
  leadId String

  @@map("ai_insights")
}

// ─── Workflow Entity (Automation Team) ───────────────────────────────────────

model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)
  hasAINodes  Boolean        @default(false)
  definition  Json           // Stores nodes[], edges{} as JSON
  metrics     Json?          // Runtime metrics JSON
  tags        String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String
  executions  WorkflowExecution[]

  @@map("workflows")
}

// ─── Workflow Execution ───────────────────────────────────────────────────────

model WorkflowExecution {
  id          String   @id @default(cuid())
  status      String   // running | completed | failed | paused
  leadId      String?
  context     Json?
  nodeResults Json?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  // Relations
  workflow   Workflow @relation(fields: [workflowId], references: [id])
  workflowId String

  @@map("workflow_executions")
}

// ─── Sequence Entity (Automation Team) ───────────────────────────────────────

model Sequence {
  id           String         @id @default(cuid())
  name         String
  description  String?
  status       SequenceStatus @default(DRAFT)
  durationDays Int            @default(7)
  aiEnabled    Boolean        @default(true)
  steps        Json           // SequenceStep[] as JSON
  enrollment   Json           // EnrollmentSettings as JSON
  exitRules    Json           // ExitSettings as JSON
  metrics      Json?
  tags         String[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String
  enrollments SequenceEnrollment[]

  @@map("sequences")
}

// ─── Sequence Enrollment ──────────────────────────────────────────────────────

model SequenceEnrollment {
  id                String   @id @default(cuid())
  status            String   @default("active") // active | completed | exited | paused
  currentStepNumber Int      @default(1)
  enrolledAt        DateTime @default(now())
  nextStepAt        DateTime?
  exitedAt          DateTime?
  exitReason        String?
  stepHistory       Json?

  // Relations
  sequence   Sequence @relation(fields: [sequenceId], references: [id])
  sequenceId String
  lead       Lead     @relation(fields: [leadId], references: [id])
  leadId     String

  @@map("sequence_enrollments")
}

// ─── Event Log (Automation Team) ─────────────────────────────────────────────

model EventLog {
  id          String        @id @default(cuid())
  type        String        // EventType string
  category    EventCategory
  entityId    String
  entityType  String
  userId      String?
  payload     Json
  metadata    Json?
  processed   Boolean       @default(false)
  processedAt DateTime?
  timestamp   DateTime      @default(now())

  @@index([type, timestamp])
  @@index([entityId, entityType])
  @@map("event_logs")
}
