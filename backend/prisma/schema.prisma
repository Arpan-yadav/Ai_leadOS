generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                 String               @id @default(cuid())
  name               String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  users              User[]
  leads              Lead[]
  customRoles        CustomRole[]
  tenantSettingsId   String?
  Deal               Deal[]
  Task               Task[]
  Activity           Activity[]
  AIInsight          AIInsight[]
  Workflow           Workflow[]
  WorkflowExecution  WorkflowExecution[]
  Sequence           Sequence[]
  SequenceEnrollment SequenceEnrollment[]
  CommunicationLog   CommunicationLog[]
  TenantSettings     TenantSettings?

  @@map("tenants")
}

model CustomRole {
  id          String  @id @default(cuid())
  name        String
  permissions Json // stores granular permissions e.g. { viewAllLeads: true }
  isDefault   Boolean @default(false)
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@map("custom_roles")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  password     String
  isSuperAdmin Boolean @default(false)
  tenantId     String?
  tenant       Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  roleId            String?
  role              CustomRole?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  avatar            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activities        Activity[]
  communicationLogs CommunicationLog[]
  deals             Deal[]
  leads             Lead[]
  sequences         Sequence[]
  tasks             Task[]
  workflows         Workflow[]

  @@map("users")
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  email         String
  company       String
  title         String?
  phone         String?
  website       String?
  linkedin      String?
  status        LeadStatus @default(NEW)
  source        LeadSource @default(WEBSITE)
  score         Int        @default(0)
  lastContacted DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tenantId      String?
  tenant        Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assignedToId       String?
  activities         Activity[]
  aiInsights         AIInsight[]
  communicationLogs  CommunicationLog[]
  deals              Deal[]
  assignedTo         User?                @relation(fields: [assignedToId], references: [id])
  enrollments        SequenceEnrollment[]
  tasks              Task[]
  workflowExecutions WorkflowExecution[]

  @@map("leads")
}

model Deal {
  id                String    @id @default(cuid())
  title             String
  amount            Float
  stage             DealStage @default(DISCOVERY)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leadId            String
  ownerId           String
  lead              Lead      @relation(fields: [leadId], references: [id])
  owner             User      @relation(fields: [ownerId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("deals")
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?
  priority     String    @default("medium")
  status       String    @default("pending")
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedToId String
  leadId       String?
  assignedTo   User      @relation(fields: [assignedToId], references: [id])
  lead         Lead?     @relation(fields: [leadId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  content   String
  timestamp DateTime @default(now())
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("activities")
}

model AIInsight {
  id            String   @id @default(cuid())
  analysis      String
  opportunities String[]
  websiteAudit  String?
  sentiment     String
  qualityScore  Int
  qualityReason String
  nextAction    String?
  rawResponse   Json?
  model         String   @default("gemini-1.5-flash")
  promptKey     String?
  createdAt     DateTime @default(now())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}

model Workflow {
  id          String              @id @default(cuid())
  name        String
  description String?
  status      WorkflowStatus      @default(DRAFT)
  hasAINodes  Boolean             @default(false)
  definition  Json
  metrics     Json?
  tags        String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdById String
  executions  WorkflowExecution[]
  createdBy   User                @relation(fields: [createdById], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("workflows")
}

model WorkflowExecution {
  id          String    @id @default(cuid())
  status      String
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id])
  context     Json?
  nodeResults Json?
  currentStep Int       @default(1)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  workflowId  String
  workflow    Workflow  @relation(fields: [workflowId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("workflow_executions")
}

model Sequence {
  id           String               @id @default(cuid())
  name         String
  description  String?
  status       SequenceStatus       @default(DRAFT)
  durationDays Int                  @default(7)
  aiEnabled    Boolean              @default(true)
  steps        Json
  enrollment   Json
  exitRules    Json
  metrics      Json?
  tags         String[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdById  String
  enrollments  SequenceEnrollment[]
  createdBy    User                 @relation(fields: [createdById], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sequences")
}

model SequenceEnrollment {
  id                String    @id @default(cuid())
  status            String    @default("active")
  currentStepNumber Int       @default(1)
  enrolledAt        DateTime  @default(now())
  nextStepAt        DateTime?
  exitedAt          DateTime?
  exitReason        String?
  stepHistory       Json?
  sequenceId        String
  leadId            String
  lead              Lead      @relation(fields: [leadId], references: [id])
  sequence          Sequence  @relation(fields: [sequenceId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sequence_enrollments")
}

model EventLog {
  id          String        @id @default(cuid())
  type        String
  category    EventCategory
  entityId    String
  entityType  String
  userId      String?
  payload     Json
  metadata    Json?
  processed   Boolean       @default(false)
  processedAt DateTime?
  timestamp   DateTime      @default(now())

  @@index([type, timestamp])
  @@index([entityId, entityType])
  @@map("event_logs")
}

model CommunicationLog {
  id          String    @id @default(cuid())
  channel     String
  direction   String
  status      String
  subject     String?
  content     String
  metadata    Json?
  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  leadId      String
  userId      String?
  lead        Lead      @relation(fields: [leadId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("communication_logs")
}

enum Role {
  ADMIN
  MANAGER
  EXECUTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum LeadSource {
  WHATSAPP
  EMAIL
  META_LEADS
  LINKEDIN
  WEBSITE
  COLD_OUTREACH
  REFERRAL
}

enum DealStage {
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  CLOSING
  WON
  LOST
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum EventCategory {
  CRM
  COMMUNICATION
  AI
  AUTOMATION
  SYSTEM
}

// ─── SaaS Tenant Settings (BYOK — Bring Your Own Key) ─────────────────────
model TenantSettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // AI Configuration
  geminiApiKey String? // User's own Google Gemini API key

  // WhatsApp (Meta Cloud API)
  waPhoneNumberId     String? // Meta Business Phone Number ID
  waAccessToken       String? // Meta permanent access token
  waBusinessAccountId String? // Meta Business Account ID
  waConnectionStatus  String  @default("DISCONNECTED")

  // Email Provider
  emailProvider     String  @default("SMTP") // SMTP | RESEND | GMAIL_OAUTH
  resendApiKey      String? // Resend.com API key
  smtpHost          String? // e.g. smtp.gmail.com
  smtpPort          Int? // e.g. 587
  smtpUser          String?
  smtpPass          String?
  gmailClientId     String?
  gmailClientSecret String?
  gmailRefreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_settings")
}
