generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  password          String
  role              Role               @default(EXECUTIVE)
  avatar            String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activities        Activity[]
  communicationLogs CommunicationLog[]
  deals             Deal[]
  leads             Lead[]
  sequences         Sequence[]
  tasks             Task[]
  workflows         Workflow[]

  @@map("users")
}

model Lead {
  id                String               @id @default(cuid())
  name              String
  email             String
  company           String
  title             String?
  phone             String?
  website           String?
  linkedin          String?
  status            LeadStatus           @default(NEW)
  source            LeadSource           @default(WEBSITE)
  score             Int                  @default(0)
  lastContacted     DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  assignedToId      String?
  activities        Activity[]
  aiInsights        AIInsight[]
  communicationLogs CommunicationLog[]
  deals             Deal[]
  assignedTo        User?                @relation(fields: [assignedToId], references: [id])
  enrollments       SequenceEnrollment[]
  tasks             Task[]

  @@map("leads")
}

model Deal {
  id                String    @id @default(cuid())
  title             String
  amount            Float
  stage             DealStage @default(DISCOVERY)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leadId            String
  ownerId           String
  lead              Lead      @relation(fields: [leadId], references: [id])
  owner             User      @relation(fields: [ownerId], references: [id])

  @@map("deals")
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?
  priority     String    @default("medium")
  status       String    @default("pending")
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedToId String
  leadId       String?
  assignedTo   User      @relation(fields: [assignedToId], references: [id])
  lead         Lead?     @relation(fields: [leadId], references: [id])

  @@map("tasks")
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  content   String
  timestamp DateTime @default(now())
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("activities")
}

model AIInsight {
  id            String   @id @default(cuid())
  analysis      String
  opportunities String[]
  websiteAudit  String?
  sentiment     String
  qualityScore  Int
  qualityReason String
  nextAction    String?
  rawResponse   Json?
  model         String   @default("gemini-1.5-flash")
  promptKey     String?
  createdAt     DateTime @default(now())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id])

  @@map("ai_insights")
}

model Workflow {
  id          String              @id @default(cuid())
  name        String
  description String?
  status      WorkflowStatus      @default(DRAFT)
  hasAINodes  Boolean             @default(false)
  definition  Json
  metrics     Json?
  tags        String[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdById String
  executions  WorkflowExecution[]
  createdBy   User                @relation(fields: [createdById], references: [id])

  @@map("workflows")
}

model WorkflowExecution {
  id          String    @id @default(cuid())
  status      String
  leadId      String?
  context     Json?
  nodeResults Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  workflowId  String
  workflow    Workflow  @relation(fields: [workflowId], references: [id])

  @@map("workflow_executions")
}

model Sequence {
  id           String               @id @default(cuid())
  name         String
  description  String?
  status       SequenceStatus       @default(DRAFT)
  durationDays Int                  @default(7)
  aiEnabled    Boolean              @default(true)
  steps        Json
  enrollment   Json
  exitRules    Json
  metrics      Json?
  tags         String[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdById  String
  enrollments  SequenceEnrollment[]
  createdBy    User                 @relation(fields: [createdById], references: [id])

  @@map("sequences")
}

model SequenceEnrollment {
  id                String    @id @default(cuid())
  status            String    @default("active")
  currentStepNumber Int       @default(1)
  enrolledAt        DateTime  @default(now())
  nextStepAt        DateTime?
  exitedAt          DateTime?
  exitReason        String?
  stepHistory       Json?
  sequenceId        String
  leadId            String
  lead              Lead      @relation(fields: [leadId], references: [id])
  sequence          Sequence  @relation(fields: [sequenceId], references: [id])

  @@map("sequence_enrollments")
}

model EventLog {
  id          String        @id @default(cuid())
  type        String
  category    EventCategory
  entityId    String
  entityType  String
  userId      String?
  payload     Json
  metadata    Json?
  processed   Boolean       @default(false)
  processedAt DateTime?
  timestamp   DateTime      @default(now())

  @@index([type, timestamp])
  @@index([entityId, entityType])
  @@map("event_logs")
}

model CommunicationLog {
  id          String    @id @default(cuid())
  channel     String
  direction   String
  status      String
  subject     String?
  content     String
  metadata    Json?
  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  leadId      String
  userId      String?
  lead        Lead      @relation(fields: [leadId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@map("communication_logs")
}

enum Role {
  ADMIN
  MANAGER
  EXECUTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum LeadSource {
  WHATSAPP
  EMAIL
  META_LEADS
  LINKEDIN
  WEBSITE
  COLD_OUTREACH
  REFERRAL
}

enum DealStage {
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  CLOSING
  WON
  LOST
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum EventCategory {
  CRM
  COMMUNICATION
  AI
  AUTOMATION
  SYSTEM
}
